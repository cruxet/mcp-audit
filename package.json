{
  "name": "@cruxet/mcp-audit",
  "version": "0.1.0",
  "description": "Security scanner for Model Context Protocol (MCP) configurations. Detects command injection, insecure transports, hardcoded secrets, and known CVEs across Cursor, Claude, Windsurf, VSCode, Continue, and more.",
  "homepage": "https://github.com/cruxet/mcp-audit",
  "bugs": {
    "url": "https://github.com/cruxet/mcp-audit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cruxet/mcp-audit.git"
  },
  "author": "Cruxet",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "security",
    "audit",
    "scanner",
    "cve",
    "model-context-protocol",
    "cursor",
    "claude",
    "windsurf",
    "ai-security",
    "supply-chain"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-audit": "bin/mcp-audit.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^10.3.10",
    "json5": "^2.2.3",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
